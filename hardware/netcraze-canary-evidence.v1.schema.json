{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://routerkit.invalid/schema/netcraze-canary-evidence.v1.json",
  "title": "RouterKit private Netcraze hardware-canary evidence manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "session_id",
    "packet_version",
    "release",
    "baseline_commit",
    "execution_commit",
    "execution_source",
    "compatibility_patch",
    "started_at",
    "ended_at",
    "expected_target",
    "observed_target",
    "phases",
    "artifacts",
    "cleanup_status",
    "manual_recovery_required",
    "final_outcome",
    "retention_decision"
  ],
  "properties": {
    "schema": {
      "const": "routerkit.netcraze.hardware-evidence.v1"
    },
    "session_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$"
    },
    "packet_version": {
      "const": 1
    },
    "release": {
      "const": "v0.2.0-alpha.16"
    },
    "baseline_commit": {
      "const": "c8f697635c93584e85e76a1d734f8fa797a76b51"
    },
    "execution_commit": {
      "const": "c8f697635c93584e85e76a1d734f8fa797a76b51"
    },
    "execution_source": {
      "const": "released_baseline"
    },
    "compatibility_patch": {
      "type": "null"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "ended_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "expected_target": {
      "$ref": "#/$defs/target"
    },
    "observed_target": {
      "$ref": "#/$defs/target"
    },
    "phases": {
      "type": "array",
      "maxItems": 14,
      "items": {
        "$ref": "#/$defs/phaseResult"
      }
    },
    "artifacts": {
      "type": "array",
      "maxItems": 512,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "cleanup_status": {
      "enum": [
        "not_started",
        "in_progress",
        "complete",
        "manual_recovery_required"
      ]
    },
    "manual_recovery_required": {
      "type": "boolean"
    },
    "final_outcome": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "PASS_CONTRACT_CAPTURE_ONLY",
        "PASS_DISPOSABLE_WRITE_CONTRACT",
        "PASS_FULL_CANARY",
        "PARTIAL_NEEDS_OFF_DEVICE_PATCH",
        "FAILED_ROLLBACK_COMPLETE",
        "FAILED_MANUAL_RECOVERY_REQUIRED",
        "STOP_UNSUPPORTED",
        null
      ]
    },
    "retention_decision": {
      "enum": [
        "retain_private",
        "retain_sanitized_only",
        "secure_disposal_pending",
        "securely_disposed"
      ]
    }
  },
  "$defs": {
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "firmware",
        "architecture",
        "storage_state",
        "comparison"
      ],
      "properties": {
        "model": {
          "type": "string",
          "maxLength": 160
        },
        "firmware": {
          "type": "string",
          "maxLength": 160
        },
        "architecture": {
          "type": "string",
          "maxLength": 80
        },
        "storage_state": {
          "type": "string",
          "maxLength": 160
        },
        "comparison": {
          "enum": [
            "expected_unverified",
            "match",
            "mismatch",
            "unknown"
          ]
        }
      }
    },
    "phaseResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase_id",
        "started_at",
        "ended_at",
        "outcome",
        "decision",
        "checks",
        "notes_category"
      ],
      "properties": {
        "phase_id": {
          "enum": [
            "P0_OPERATOR_PREFLIGHT",
            "P1_READ_ONLY_PLATFORM_INVENTORY",
            "P2_READ_ONLY_DEVICE_DISCOVERY_CONTRACT",
            "P3_READ_ONLY_POLICY_CONTRACT",
            "P4_OFF_DEVICE_COMPATIBILITY_DECISION",
            "P5_DISPOSABLE_CONNECTION_CANARY",
            "P6_DISPOSABLE_POLICY_CANARY",
            "P7_OPTIONAL_DISPOSABLE_ASSIGNMENT_CANARY",
            "P8_FULL_ROUTERKIT_INSTALL_CANARY",
            "P9_IDEMPOTENT_RERUN",
            "P10_FAILURE_AND_ROLLBACK",
            "P11_REBOOT_AND_RECOVERY",
            "P12_FINAL_INVARIANT_AUDIT",
            "P13_CLEANUP_AND_DEVICE_RETURN"
          ]
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "ended_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "outcome": {
          "enum": [
            "not_started",
            "pass",
            "partial",
            "fail",
            "skip"
          ]
        },
        "decision": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "GO_WITH_EXISTING_ALPHA16_CONTRACT",
            "OFF_DEVICE_NARROW_PATCH_REQUIRED",
            "STOP_UNSUPPORTED_OR_AMBIGUOUS",
            null
          ]
        },
        "checks": {
          "type": "array",
          "maxItems": 64,
          "items": {
            "$ref": "#/$defs/checkResult"
          }
        },
        "notes_category": {
          "enum": [
            "none",
            "expected",
            "limitation",
            "stop_reason",
            "rollback",
            "cleanup"
          ]
        }
      }
    },
    "checkResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_id",
        "outcome"
      ],
      "properties": {
        "check_id": {
          "type": "string",
          "pattern": "^P(?:[0-9]|1[0-3])_[A-Z0-9_]+$"
        },
        "outcome": {
          "enum": [
            "pass",
            "partial",
            "fail",
            "skip"
          ]
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "phase_id",
        "check_id",
        "reference_kind",
        "reference",
        "byte_size",
        "sha256",
        "sensitivity_class",
        "retention_decision",
        "redaction_status",
        "notes_category"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$"
        },
        "phase_id": {
          "type": "string",
          "pattern": "^P(?:[0-9]|1[0-3])_[A-Z0-9_]+$"
        },
        "check_id": {
          "type": "string",
          "pattern": "^P(?:[0-9]|1[0-3])_[A-Z0-9_]+$"
        },
        "reference_kind": {
          "enum": [
            "local_filename",
            "opaque_reference"
          ]
        },
        "reference": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,159}$"
        },
        "byte_size": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1073741824
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "sensitivity_class": {
          "enum": [
            "public_safe",
            "local_sensitive",
            "secret_bearing",
            "router_backup",
            "device_inventory",
            "credential_adjacent"
          ]
        },
        "retention_decision": {
          "enum": [
            "retain_private",
            "retain_sanitized_only",
            "secure_disposal_pending",
            "securely_disposed"
          ]
        },
        "redaction_status": {
          "enum": [
            "not_applicable",
            "not_started",
            "sanitized",
            "rejected_for_publication"
          ]
        },
        "notes_category": {
          "enum": [
            "none",
            "schema",
            "result",
            "limitation",
            "rollback",
            "cleanup"
          ]
        }
      }
    }
  }
}
